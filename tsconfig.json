{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "./components/*": ["./src/components/*"]
    },
    "baseUrl": "src"
  },
  "include": ["src/**/*", "content/**/*"],
  "exclude": ["node_modules", "dist"]
}
